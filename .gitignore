# Dependencies
# These folders contain thousands of files and should never be committed.
/node_modules
/backend/node_modules

# Production
# This folder is the output of the build process and is generated automatically.
/dist

# Environment Variables
# VERY IMPORTANT: This prevents your secret API keys from being uploaded to GitHub.
.env
.env.local
.env.*.local
/backend/.env

# Logs
# Log files are specific to your machine and don't belong in the repository.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System files
# Common OS-generated files.
.DS_Store
Thumbs.db

# IDE / Editor directories
# Configuration files for code editors.
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp